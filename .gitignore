# ============================================================
# DINOv2/YOLO 水体问题识别 - Git Ignore 配置
# ============================================================

# ============================================================
# 排除：大型数据文件（不上传）
# ============================================================
# 原始图片数据（~13.9 GB）
data/raw/
data/images/

# 处理后数据（训练集/验证集/测试集）
data/processed/

# 标注结果数据（不上传）
data/annotations/yolo_format/
data/annotations/labelme_jsons/
data/annotations/voc_xml/
data/annotations/coco_format/

# Excel 原始文件（~55 GB）
excel/

# Excel 原始文件（~55 GB）
# excel/

# 训练输出和模型权重（~1.2 GB+）
runs/

# 预训练权重
weights/

# 模型文件
*.pth
*.pt
*.ckpt
*.bin
*.safetensors

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.pyd

# 虚拟环境
venv/
env/
.venv/

# IDE
.vscode/
.idea/

# 系统文件
.DS_Store
Thumbs.db

# Jupyter checkpoints
.ipynb_checkpoints/

# 训练日志
*.log
events.out.tfevents.*

# ============================================================
# 保留的内容（✅ 可以上传）
# ============================================================
# ✅ configs/ - 配置文件
# ✅ src/ - 源代码
# ✅ notebooks/ - Jupyter Notebooks
# ✅ docs/ - 文档
# ✅ tests/ - 测试
# ✅ README.md
# ✅ requirements.txt
# ✅ data/annotations/README.md - 标注说明文档
# ✅ data/annotations/classes.txt - 类别定义
# ✅ data/annotations/data.yaml - 数据集配置
# ✅ data/annotations/annotation_template.md - 标注模板
# ✅ data/annotations/quality_checklist.md - 质量检查表
# ✅ sample_data/ - 示例数据（100 张，用于快速测试）
# ============================================================
